# Copy this file to `.env` and fill in the values for your machine.

# --- Database ---
# Point at a running Postgres server with a user/password that exist.
# The database itself (art_gallery) is created by `npx prisma migrate deploy`.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/art_gallery?schema=public"

# --- Auth.js ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-me-with-a-generated-secret"
# Allow credentials over http in dev / trust the localhost host.
AUTH_TRUST_HOST="true"

# --- Seeded admin account (used by prisma/seed.ts) ---
ADMIN_EMAIL="admin@artgallery.test"
ADMIN_PASSWORD="Admin123!"
ADMIN_NAME="Gallery Admin"

# --- Public site config ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
